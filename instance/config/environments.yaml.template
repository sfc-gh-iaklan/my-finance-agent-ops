# Instance config — YOUR project's configuration.
#
# This file is populated by the bootstrap-from-existing skill, or manually.
# Rename to environments.yaml after filling in your values.
#
# Universal defaults (llm models, Snowflake credit pricing) live in the
# framework's config/defaults.yaml and are merged UNDER this file by
# evaluation/utils.load_config() — so you may override them here if needed.
#
# All *_path / *_dir values are resolved relative to THIS instance directory.

# Snowflake connection (named connection in ~/.snowflake/connections.toml)
connection_name: default

# Framework infrastructure — where the framework stores its own tables/views.
# This is the ONLY schema the framework creates objects in.
framework:
  database: {{FRAMEWORK_DB}}        # e.g. MY_PROJECT_OPS or an existing DB
  schema: {{FRAMEWORK_SCHEMA}}      # e.g. AGENTOPS (created if not exists)
  warehouse: {{WAREHOUSE}}          # existing warehouse to use

# Environments — references to YOUR existing semantic views and agents.
# Only 'dev' is required for bootstrapping. 'prod' is populated when CI/CD is set up.
environments:
  dev:
    semantic_views:
      # List of semantic views to govern in this environment.
      # Each entry has:
      #   fqn: fully qualified name (DATABASE.SCHEMA.VIEW_NAME)
      #   short_name: display name used in reports and question banks
      - fqn: {{SV_FQN}}
        short_name: {{SV_SHORT_NAME}}

    agents:
      # List of agents to govern in this environment.
      # Each entry has:
      #   fqn: fully qualified name (DATABASE.SCHEMA.AGENT_NAME)
      #   short_name: display name used in reports
      #   semantic_views: list of SV FQNs bound to this agent (resolved from DESCRIBE AGENT)
      - fqn: {{AGENT_FQN}}
        short_name: {{AGENT_SHORT_NAME}}
        semantic_views:
          - {{SV_FQN}}

  prod:  # populated later when CI/CD promotion is configured
    semantic_views: []
    agents: []

# Question bank locations (relative to this instance directory).
question_banks:
  agent_dir: question_banks/agent
  semantic_view_dir: question_banks/semantic_view
